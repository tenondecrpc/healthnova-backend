# Core app
ENV_NAME=dev
PROJECT_NAME=healthnova
AWS_ACCOUNT_ID=xxxxxxxx672
AWS_REGION=us-east-1

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://app.mydomain.com,http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With,Accept,Origin,X-Api-Key
CORS_MAX_AGE=86400

# Health Data Ingestion
EXPORTS_BUCKET_NAME=your-bucket-name
PRESIGNED_URL_EXPIRY_SECONDS=3600

# Repository
GH_ORG=your-org
GH_REPO=healthnova-backend

# Cost Management
MONTHLY_BUDGET_USD=100
BUDGET_ALERT_EMAILS=your@email.com,other@email.com
BUDGET_ALERT_PHONES=+5491112345678,5491112345679

# GitHub Actions Secrets (not needed locally — set in repo Settings > Secrets)
# CLAUDE_API_KEY=sk-ant-...              # Anthropic API key (security-review workflow)
# INFRACOST_API_KEY=ico-...              # Infracost API key (cost-estimate workflow)
# AWS_CDK_DIFF_ROLE_ARN=arn:aws:iam::... # Output from CDK deploy (GithubOidcFactoryGithubActionsCdkDiffRoleArn)